@page
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer
@model IndexModel
@{
    ViewData["Title"] = Localizer["Home.Title"];
    var slotColumnOne = Model.CurrentLanguage == SupportedLanguage.EnUs ? new[] { "B", "L", "D" } : new[] { "早", "午", "晚" };
    var slotColumnTwo = Model.CurrentLanguage == SupportedLanguage.EnUs ? new[] { "Rice", "Noodle", "Soup" } : new[] { "飯", "麵", "湯" };
    var slotColumnThree = Model.CurrentLanguage == SupportedLanguage.EnUs ? new[] { "Fresh", "Savory", "Warm" } : new[] { "鮮", "香", "熱" };
}

<section class="slot-page" aria-labelledby="draw-title">
    <div class="slot-header">
        <p class="slot-kicker">@Localizer["Home.Kicker"]</p>
        <h1 id="draw-title">@Localizer["Home.Title"]</h1>
    </div>

    <section class="theme-mode-panel" data-theme-mode-selector aria-labelledby="theme-mode-title">
        <fieldset class="theme-mode-fieldset">
            <legend id="theme-mode-title">@Localizer["Theme.Title"]</legend>
            <div class="theme-mode-options" role="radiogroup" aria-label="@Localizer["Theme.Title"]">
                <input class="btn-check theme-mode-input" type="radio" name="theme-mode" id="theme-mode-light" value="light" autocomplete="off" />
                <label class="btn theme-mode-option" for="theme-mode-light">@Localizer["Theme.Light"]</label>

                <input class="btn-check theme-mode-input" type="radio" name="theme-mode" id="theme-mode-dark" value="dark" autocomplete="off" />
                <label class="btn theme-mode-option" for="theme-mode-dark">@Localizer["Theme.Dark"]</label>

                <input class="btn-check theme-mode-input" type="radio" name="theme-mode" id="theme-mode-system" value="system" autocomplete="off" />
                <label class="btn theme-mode-option" for="theme-mode-system">@Localizer["Theme.System"]</label>
            </div>
        </fieldset>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        var alertClass = Model.OperationState == DrawOperationState.Blocked ? "alert-danger" : "alert-info";
        <div class="alert @alertClass" role="status" id="draw-state">@Model.StatusMessage</div>
    }

    <form method="post"
          asp-page-handler="Draw"
          class="slot-console"
          data-draw-form
          data-draw-state-spinning="@Localizer["Home.Status.Spinning"]"
          data-draw-state-reduced="@Localizer["Home.Status.Revealing"]">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>
        <input type="hidden" name="drawOperationId" value="@Model.DrawOperationId" />

        <fieldset class="draw-mode-selector" disabled="@Model.IsBlocked" data-draw-mode-selector>
            <legend>@Localizer["Home.Mode.Legend"]</legend>
            <div class="draw-mode-options" role="radiogroup" aria-label="@Localizer["Home.Mode.Legend"]">
                <input class="btn-check"
                       type="radio"
                       name="drawMode"
                       id="draw-mode-normal"
                       value="@DrawMode.Normal"
                       checked="@(Model.DrawMode == DrawMode.Normal)" />
                <label class="btn draw-mode-option" for="draw-mode-normal">@Localizer["Home.Mode.Normal"]</label>

                <input class="btn-check"
                       type="radio"
                       name="drawMode"
                       id="draw-mode-random"
                       value="@DrawMode.Random"
                       checked="@(Model.DrawMode == DrawMode.Random)" />
                <label class="btn draw-mode-option" for="draw-mode-random">@Localizer["Home.Mode.Random"]</label>
            </div>
        </fieldset>

        <fieldset class="meal-selector"
                  disabled="@(Model.IsBlocked || Model.DrawMode == DrawMode.Random)"
                  data-meal-selector
                  data-server-blocked="@(Model.IsBlocked ? "true" : "false")">
            <legend>@Localizer["Home.MealSelector.Legend"]</legend>
            <div class="meal-options" role="radiogroup" aria-label="@Localizer["Home.MealSelector.Legend"]">
                @foreach (var mealType in Model.MealTypes)
                {
                    var id = $"meal-{mealType}";
                    <input class="btn-check" type="radio" asp-for="MealType" id="@id" value="@mealType" />
                    <label class="btn meal-option" for="@id">@mealType.ToDisplayName(Model.CurrentLanguage)</label>
                }
            </div>
            <span asp-validation-for="MealType" class="text-danger"></span>
        </fieldset>

        <fieldset class="metadata-filter-panel" disabled="@Model.IsBlocked" data-metadata-filter-panel>
            <legend>@Localizer["Home.Filters.Legend"]</legend>
            <div class="metadata-filter-grid">
                <div class="filter-field">
                    <label class="form-label" for="filter-price">@Localizer["Metadata.Label.PriceRange"]</label>
                    <select class="form-select" id="filter-price" name="PriceRange">
                        <option value="">@Localizer["Metadata.Option.NotSet"]</option>
                        @foreach (var priceRange in Model.PriceRangeOptions)
                        {
                            <option value="@priceRange" selected="@(Model.PriceRange == priceRange ? "selected" : null)">@Model.DisplayPriceRange(priceRange)</option>
                        }
                    </select>
                </div>

                <div class="filter-field">
                    <label class="form-label" for="filter-time">@Localizer["Metadata.Label.PreparationTimeRange"]</label>
                    <select class="form-select" id="filter-time" name="PreparationTimeRange">
                        <option value="">@Localizer["Metadata.Option.NotSet"]</option>
                        @foreach (var preparationTimeRange in Model.PreparationTimeRangeOptions)
                        {
                            <option value="@preparationTimeRange" selected="@(Model.PreparationTimeRange == preparationTimeRange ? "selected" : null)">@Model.DisplayPreparationTimeRange(preparationTimeRange)</option>
                        }
                    </select>
                </div>

                <div class="filter-field">
                    <label class="form-label" for="filter-spice">@Localizer["Metadata.Label.SpiceLevel"]</label>
                    <select class="form-select" id="filter-spice" name="MaxSpiceLevel">
                        <option value="">@Localizer["Metadata.Option.NotSet"]</option>
                        @foreach (var spiceLevel in Model.SpiceLevelOptions)
                        {
                            <option value="@spiceLevel" selected="@(Model.MaxSpiceLevel == spiceLevel ? "selected" : null)">@Model.DisplaySpiceLevel(spiceLevel)</option>
                        }
                    </select>
                </div>

                <div class="filter-field filter-field-wide">
                    <label class="form-label" for="filter-tags">@Localizer["Metadata.Label.Tags"]</label>
                    <input class="form-control"
                           id="filter-tags"
                           name="Tags"
                           value="@string.Join(", ", Model.Tags)"
                           placeholder="@Localizer["Home.Filters.TagsPlaceholder"]" />
                </div>

                <div class="filter-field filter-field-wide">
                    <p class="form-label mb-2">@Localizer["Metadata.Label.DietaryPreferences"]</p>
                    <div class="metadata-checkbox-grid">
                        @foreach (var preference in Model.DietaryPreferenceOptions)
                        {
                            var preferenceId = $"diet-{preference}";
                            <div class="form-check">
                                <input class="form-check-input"
                                       type="checkbox"
                                       id="@preferenceId"
                                       name="DietaryPreferences"
                                       value="@preference"
                                       checked="@(Model.DietaryPreferences.Contains(preference) ? "checked" : null)" />
                                <label class="form-check-label" for="@preferenceId">@Model.DisplayDietaryPreference(preference)</label>
                            </div>
                        }
                    </div>
                </div>
            </div>

            @if (!Model.CurrentFilterSummary.IsEmpty)
            {
                <div class="active-filter-summary" data-filter-summary>
                    <span>@Localizer["Metadata.Filter.Summary", string.Join(" / ", Model.CurrentFilterSummary.Items)]</span>
                    <div class="filter-chip-list" aria-label="@Localizer["Home.Filters.ActiveConditions"]">
                        @foreach (var item in Model.CurrentFilterSummary.Items)
                        {
                            <span class="filter-chip" data-tag-chip>@item</span>
                        }
                    </div>
                    <a class="btn btn-outline-secondary btn-sm" asp-page="/Index">@Localizer["Home.Filters.Clear"]</a>
                </div>
            }
        </fieldset>

        <div class="slot-machine" aria-label="@Localizer["Home.Slot.Aria"]" data-slot-machine>
            <div class="slot-reel">
                @foreach (var symbol in slotColumnOne)
                {
                    <span>@symbol</span>
                }
            </div>
            <div class="slot-reel">
                @foreach (var symbol in slotColumnTwo)
                {
                    <span>@symbol</span>
                }
            </div>
            <div class="slot-reel">
                @foreach (var symbol in slotColumnThree)
                {
                    <span>@symbol</span>
                }
            </div>
        </div>

        <div class="draw-controls">
            <div class="form-check coin-control">
                <input asp-for="CoinInserted" class="form-check-input" disabled="@Model.IsBlocked" />
                <label asp-for="CoinInserted" class="form-check-label">@Localizer["Home.Coin.Label"]</label>
            </div>
            <span asp-validation-for="CoinInserted" class="text-danger"></span>

            <button type="submit" class="btn btn-danger lever-button" disabled="@Model.IsBlocked" data-draw-submit>
                @Localizer["Home.Draw.Button"]
            </button>
        </div>
    </form>

    @if (Model.Result?.Succeeded == true)
    {
        <section class="draw-result" aria-labelledby="draw-result-title" data-result-card-id="@Model.Result.CardId">
            <p class="slot-kicker">@Localizer["Home.Result.Kicker"]</p>
            <h2 id="draw-result-title">@Model.Result.Name</h2>
            <p class="draw-mode-badge">@(Model.Result.DrawMode == DrawMode.Random ? Localizer["Home.Mode.Random"] : Localizer["Home.Mode.Normal"])</p>
            <p class="meal-badge">@Model.Result.MealTypeDisplayName</p>
            <p>@Model.Result.Description</p>
            @if (Model.Result.LocalizedCard?.IsFallback == true)
            {
                <p class="fallback-badge">@Localizer["Card.NeedsEnglishTranslation"]</p>
            }
            @if (Model.Result.LocalizedCard?.MetadataBadges?.Count > 0)
            {
                <div class="metadata-badge-list" aria-label="@Localizer["Home.Result.MetadataSummary"]">
                    @foreach (var badge in Model.Result.LocalizedCard.MetadataBadges)
                    {
                        <span class="metadata-badge" data-metadata-badge>@badge</span>
                    }
                </div>
            }
        </section>
    }

    <section class="draw-statistics" aria-labelledby="draw-statistics-title">
        <div class="statistics-heading">
            <div>
                <p class="slot-kicker">@Localizer["Statistics.Kicker"]</p>
                <h2 id="draw-statistics-title">@Localizer["Statistics.Title"]</h2>
            </div>
            <p class="statistics-total">@Localizer["Statistics.Total"] <strong>@Model.Statistics.TotalSuccessfulDraws</strong></p>
        </div>

        @if (!Model.Statistics.HasHistory)
        {
            <p class="statistics-empty">@Localizer["Statistics.Empty"]</p>
        }
        else
        {
            <div class="table-responsive statistics-table-wrap">
                <table class="table statistics-table align-middle">
                    <thead>
                        <tr>
                            <th scope="col">@Localizer["Statistics.CardName"]</th>
                            <th scope="col">@Localizer["Statistics.MealType"]</th>
                            <th scope="col">@Localizer["Statistics.DrawCount"]</th>
                            <th scope="col">@Localizer["Statistics.Probability"]</th>
                            <th scope="col">@Localizer["Statistics.Status"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Statistics.Rows)
                        {
                            <tr>
                                <td>@row.DisplayName</td>
                                <td>@row.MealTypeDisplayName</td>
                                <td>@row.DrawCount</td>
                                <td>@row.HistoricalProbabilityDisplay</td>
                                <td>
                                    <span class="card-status-badge @(row.Status == CardStatus.Deleted ? "is-deleted" : "is-active")">
                                        @(row.Status == CardStatus.Deleted ? Localizer["Statistics.Status.Deleted"] : Localizer["Statistics.Status.Active"])
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
