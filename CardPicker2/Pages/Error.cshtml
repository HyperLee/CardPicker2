@page
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer
@model ErrorModel
@{
    ViewData["Title"] = Localizer["Error.Title"];
}

<section class="error-page" aria-labelledby="error-title">
    <h1 id="error-title" class="text-danger">@Localizer["Error.Heading"]</h1>
    <p>@Localizer["Error.Message"]</p>

    @if (Model.ShowRequestId)
    {
        <p>
            <strong>@Localizer["Error.RequestId"]</strong>
            <code>@Model.RequestId</code>
        </p>
    }
</section>
