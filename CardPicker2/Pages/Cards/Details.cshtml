@page "/Cards/{id:guid}"
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer
@model CardPicker2.Pages.Cards.DetailsModel
@{
    ViewData["Title"] = Model.Card?.DisplayName ?? Localizer["Details.Title"];
}

<section class="card-detail" aria-labelledby="card-detail-title">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success" role="status">@Model.StatusMessage</div>
    }

    @if (Model.IsBlocked)
    {
        <div class="alert alert-danger" role="alert">@Model.Message</div>
    }
    else if (Model.Card is null)
    {
        <div class="alert alert-warning" role="alert">@Model.Message</div>
    }
    else
    {
        <p class="slot-kicker">@Localizer["Details.Kicker"]</p>
        <h1 id="card-detail-title">@Model.Card.DisplayName</h1>
        <p class="meal-badge">@Model.Card.MealTypeDisplayName</p>
        <p class="card-description">@Model.Card.DisplayDescription</p>
        @if (Model.Card.IsFallback)
        {
            <p class="fallback-badge">@Localizer["Card.NeedsEnglishTranslation"]</p>
        }

        <div class="detail-actions">
            <a class="btn btn-danger" href="/Cards/Edit/@Model.Card.CardId">@Localizer["Details.EditCard"]</a>
        </div>

        <form method="post" asp-page-handler="Delete" asp-route-id="@Model.Card.CardId" class="delete-panel">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>
            <div class="form-check">
                <input asp-for="ConfirmDelete" class="form-check-input" />
                <label asp-for="ConfirmDelete" class="form-check-label">@Localizer["Details.DeleteConfirmLabel"]</label>
            </div>
            <button type="submit" class="btn btn-outline-danger mt-3">@Localizer["Details.DeleteButton"]</button>
        </form>
    }

    <a class="btn btn-outline-secondary" asp-page="/Cards/Index">@Localizer["Details.BackToCards"]</a>
</section>
