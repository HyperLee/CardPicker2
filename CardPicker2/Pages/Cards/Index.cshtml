@page
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer
@model CardPicker2.Pages.Cards.IndexModel
@{
    ViewData["Title"] = Localizer["Cards.Title"];
}

<section class="card-library" aria-labelledby="cards-title">
    <div class="page-heading">
        <p class="slot-kicker">@Localizer["Cards.Kicker"]</p>
        <h1 id="cards-title">@Localizer["Cards.Title"]</h1>
    </div>

    @if (Model.IsBlocked)
    {
        <div class="alert alert-danger" role="alert">@Model.LibraryState?.UserMessage</div>
    }
    else if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success" role="status">@Model.StatusMessage</div>
    }

    <div class="management-bar">
        <a class="btn btn-danger" asp-page="/Cards/Create">@Localizer["Cards.Create"]</a>
    </div>

    <form method="get" class="search-panel card-search-panel" role="search" data-language-preserve-form="cards-search">
        <div class="filter-field">
            <label asp-for="Keyword" class="form-label">@Localizer["Cards.KeywordLabel"]</label>
            <input asp-for="Keyword" class="form-control" placeholder="@Localizer["Cards.KeywordPlaceholder"]" />
        </div>
        <div class="filter-field">
            <label asp-for="MealType" class="form-label">@Localizer["Cards.MealTypeLabel"]</label>
            <select asp-for="MealType" class="form-select">
                <option value="">@Localizer["Cards.AllMealTypes"]</option>
                @foreach (var mealType in Model.MealTypes)
                {
                    <option value="@mealType">@mealType.ToDisplayName(Model.CurrentLanguage)</option>
                }
            </select>
        </div>
        <div class="filter-field">
            <label asp-for="PriceRange" class="form-label">@Localizer["Metadata.Label.PriceRange"]</label>
            <select asp-for="PriceRange" class="form-select">
                <option value="">@Localizer["Metadata.Option.NotSet"]</option>
                @foreach (var priceRange in Model.PriceRangeOptions)
                {
                    <option value="@priceRange">@Model.DisplayPriceRange(priceRange)</option>
                }
            </select>
        </div>
        <div class="filter-field">
            <label asp-for="PreparationTimeRange" class="form-label">@Localizer["Metadata.Label.PreparationTimeRange"]</label>
            <select asp-for="PreparationTimeRange" class="form-select">
                <option value="">@Localizer["Metadata.Option.NotSet"]</option>
                @foreach (var preparationTimeRange in Model.PreparationTimeRangeOptions)
                {
                    <option value="@preparationTimeRange">@Model.DisplayPreparationTimeRange(preparationTimeRange)</option>
                }
            </select>
        </div>
        <div class="filter-field">
            <label asp-for="MaxSpiceLevel" class="form-label">@Localizer["Metadata.Label.SpiceLevel"]</label>
            <select asp-for="MaxSpiceLevel" class="form-select">
                <option value="">@Localizer["Metadata.Option.NotSet"]</option>
                @foreach (var spiceLevel in Model.SpiceLevelOptions)
                {
                    <option value="@spiceLevel">@Model.DisplaySpiceLevel(spiceLevel)</option>
                }
            </select>
        </div>
        <div class="filter-field filter-field-wide">
            <label asp-for="Tags" class="form-label">@Localizer["Metadata.Label.Tags"]</label>
            <input class="form-control"
                   id="Tags"
                   name="Tags"
                   value="@string.Join(", ", Model.Tags)"
                   placeholder="@Localizer["Home.Filters.TagsPlaceholder"]" />
        </div>
        <div class="filter-field filter-field-wide">
            <p class="form-label mb-2">@Localizer["Metadata.Label.DietaryPreferences"]</p>
            <div class="metadata-checkbox-grid">
                @foreach (var preference in Model.DietaryPreferenceOptions)
                {
                    var preferenceId = $"cards-diet-{preference}";
                    <div class="form-check">
                        <input class="form-check-input"
                               type="checkbox"
                               id="@preferenceId"
                               name="DietaryPreferences"
                               value="@preference"
                               checked="@(Model.DietaryPreferences.Contains(preference) ? "checked" : null)" />
                        <label class="form-check-label" for="@preferenceId">@Model.DisplayDietaryPreference(preference)</label>
                    </div>
                }
            </div>
        </div>
        <div class="search-actions">
            <button class="btn btn-danger" type="submit" disabled="@Model.IsBlocked">@Localizer["Cards.Search"]</button>
            <a class="btn btn-outline-secondary" asp-page="/Cards/Index">@Localizer["Cards.Clear"]</a>
        </div>
    </form>

    @if (!Model.IsBlocked && !Model.CurrentFilterSummary.IsEmpty)
    {
        <div class="active-filter-summary" data-filter-summary>
            <span>@Localizer["Metadata.Filter.Summary", string.Join(" / ", Model.CurrentFilterSummary.Items)]</span>
            <div class="filter-chip-list" aria-label="@Localizer["Home.Filters.ActiveConditions"]">
                @foreach (var item in Model.CurrentFilterSummary.Items)
                {
                    <span class="filter-chip" data-tag-chip>@item</span>
                }
            </div>
        </div>
    }

    @if (!Model.IsBlocked)
    {
        <p class="cards-result-count" role="status">@Localizer["Cards.ResultCount", Model.Cards.Count]</p>
    }

    @if (!Model.IsBlocked && Model.Cards.Count == 0)
    {
        <div class="empty-state" role="status">@Model.EmptyStateMessage</div>
    }
    else if (!Model.IsBlocked)
    {
        <div class="meal-card-list" aria-label="@Localizer["Cards.ListAria"]">
            @foreach (var card in Model.Cards)
            {
                <article class="meal-card-item">
                    <div>
                        <h2>@card.DisplayName</h2>
                        <p class="meal-badge">@card.MealTypeDisplayName</p>
                        @if (card.IsFallback)
                        {
                            <p class="fallback-badge">@Localizer["Card.NeedsEnglishTranslation"]</p>
                        }
                        @if (card.MetadataBadges?.Count > 0)
                        {
                            <div class="metadata-badge-list" aria-label="@Localizer["Home.Result.MetadataSummary"]">
                                @foreach (var badge in card.MetadataBadges)
                                {
                                    <span class="metadata-badge" data-metadata-badge>@badge</span>
                                }
                            </div>
                        }
                    </div>
                    <div class="card-actions">
                        <a class="btn btn-outline-danger" href="/Cards/@card.CardId">@Localizer["Cards.Details"]</a>
                        <a class="btn btn-outline-secondary" href="/Cards/Edit/@card.CardId">@Localizer["Cards.Edit"]</a>
                    </div>
                </article>
            }
        </div>
    }
</section>
