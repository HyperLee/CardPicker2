{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug CardPicker2 (HTTPS)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/CardPicker2/bin/Debug/net10.0/CardPicker2.dll",
      "args": [],
      "cwd": "${workspaceFolder}/CardPicker2",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:7086;http://localhost:5013"
      }
    },
    {
      "name": "Debug CardPicker2 (HTTP)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/CardPicker2/bin/Debug/net10.0/CardPicker2.dll",
      "args": [],
      "cwd": "${workspaceFolder}/CardPicker2",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5013"
      }
    },
    {
      "name": "Attach to .NET Process",
      "type": "coreclr",
      "request": "attach"
    }
  ]
}
